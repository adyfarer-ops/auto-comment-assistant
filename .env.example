PORT=3000
NODE_ENV=development

# 飞书应用凭证（操作表格）
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# 飞书通知应用凭证（消息推送）
FEISHU_NOTIFY_APP_ID=cli_xxx
FEISHU_NOTIFY_APP_SECRET=xxx

# TikHub API
TIKHUB_API_KEY=xxx
TIKHUB_BASE_URL=https://api.tikhub.io

# YouTube Data API v3
YOUTUBE_API_KEY=xxx

# AI API Keys
MOONSHOT_API_KEY=sk-xxx
DOUBAO_API_KEY=xxx
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 视频分析 AI (豆包/火山引擎多模态)
VIDEO_ANALYSIS_API_KEY=ark-xxx
VIDEO_ANALYSIS_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 代理设置
# 不要设置 HTTPS_PROXY，axios 会自动读取并让所有请求走代理（包括飞书）。
# 使用 APP_HTTPS_PROXY，仅代码中显式调用 createProxyAgent() 的服务（YouTube/TikHub）会使用。
APP_HTTPS_PROXY=http://127.0.0.1:7890

# Webhook 安全密钥
WEBHOOK_SECRET=your-webhook-secret

# 项目配置
PROJECT_MANAGEMENT_TABLE_TOKEN=GEZ9bWr5kaexSEssvUaczO0Knhh

# 哼哼猫视频解析 API
HENGHENGMAO_API_KEY=xxx
HENGHENGMAO_BASE_URL=https://api.henghhengmao.com

# 飞书通知会话 ID
NOTIFY_CHAT_ID=oc_xxx

# 飞书 Base Token（可选，用于跨 Base 操作）
FEISHU_BASE_TOKEN=xxx
FEISHU_DETAIL_BASE_TOKEN=xxx

# 飞书个人访问令牌（可选）
FEISHU_PERSONAL_TOKEN=xxx

# AI 模型选择（moonshot / doubao / deepseek）
AI_MODEL=doubao

# AI 视觉模型（视频分析）
AI_VISION_MODEL=doubao-vision-pro-32k
