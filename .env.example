PORT=3000
NODE_ENV=development

# 飞书应用凭证（操作表格）
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# 飞书通知应用凭证（消息推送）
FEISHU_NOTIFY_APP_ID=cli_xxx
FEISHU_NOTIFY_APP_SECRET=xxx

# TikHub API
TIKHUB_API_KEY=xxx
TIKHUB_BASE_URL=https://api.tikhub.io

# YouTube Data API v3
YOUTUBE_API_KEY=xxx

# AI API Keys
MOONSHOT_API_KEY=sk-xxx
DOUBAO_API_KEY=xxx
DEEPSEEK_API_KEY=sk-xxx

# 代理设置
HTTPS_PROXY=http://127.0.0.1:7890

# 项目配置
PROJECT_MANAGEMENT_TABLE_TOKEN=xxx
